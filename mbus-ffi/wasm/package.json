{
  "name": "modbus-rs-wasm",
  "version": "0.15.2",
  "description": "Modbus TCP/RTU/ASCII client & server for the browser, powered by Rust + WebAssembly",
  "type": "module",
  "exports": {
    ".": {
      "node": "./dist/bundler/modbus-rs.js",
      "import": "./dist/bundler/modbus-rs.js",
      "require": "./dist/bundler/modbus-rs.js",
      "types": "./dist/bundler/modbus-rs.d.ts"
    },
    "./web": {
      "import": "./dist/web/modbus-rs.js",
      "types": "./dist/web/modbus-rs.d.ts"
    },
    "./dist/bundler/*": "./dist/bundler/*",
    "./dist/web/*": "./dist/web/*"
  },
  "main": "dist/bundler/modbus-rs.js",
  "module": "dist/bundler/modbus-rs.js",
  "types": "dist/bundler/modbus-rs.d.ts",
  "files": [
    "dist/web/modbus-rs.js",
    "dist/web/modbus-rs.d.ts",
    "dist/web/modbus-rs_bg.wasm",
    "dist/web/modbus-rs_bg.wasm.d.ts",
    "dist/bundler/modbus-rs.js",
    "dist/bundler/modbus-rs.d.ts",
    "dist/bundler/modbus-rs_bg.wasm",
    "dist/bundler/modbus-rs_bg.js",
    "dist/bundler/modbus-rs_bg.wasm.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:web": "wasm-pack build ../. --target web --out-name modbus-rs --out-dir wasm/dist/web --features wasm-full",
    "build:bundler": "wasm-pack build ../. --target bundler --out-name modbus-rs --out-dir wasm/dist/bundler --features wasm-full",
    "build": "npm run build:web && npm run build:bundler && rm -f dist/web/.gitignore dist/bundler/.gitignore dist/web/package.json dist/bundler/package.json dist/web/README.md dist/bundler/README.md",
    "test": "npm run build:web && rm -f dist/web/.gitignore && vitest run --reporter=verbose",
    "test:watch": "vitest --browser",
    "verify": "node verify-dist.js"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "esbuild": "^0.28.1",
    "playwright": "^1.50.0",
    "rollup": "^4.62.2",
    "vite": "^8.1.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.9",
    "ws": "^8.18.0"
  },
  "keywords": [
    "modbus",
    "wasm",
    "webassembly",
    "websocket",
    "web-serial",
    "modbus-tcp",
    "modbus-rtu",
    "modbus-ascii",
    "scada",
    "plc",
    "industrial",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raghava-Ch/modbus-rs.git"
  },
  "author": "Raghava-Ch",
  "license": "GPL-3.0-only"
}
