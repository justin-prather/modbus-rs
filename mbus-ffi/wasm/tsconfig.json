{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "lib": ["ESNext"]
  },
  "include": ["dist/**/*.d.ts", "examples/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "target"]
}
